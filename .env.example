# ---- Google Calendar OAuth (server-side only — never shipped to the browser) ----
# Create these in Google Cloud Console (see README "One-time Google setup").
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Captured ONCE by visiting /api/auth/start after deploying. The long-lived
# refresh token that keeps the kiosk authorized for months. Paste it here (local)
# and into Vercel project env vars (production).
GOOGLE_REFRESH_TOKEN=

# Optional: comma-separated calendar IDs to show. Leave blank to show all
# calendars on the account.
GOOGLE_CALENDAR_IDS=

# Optional: override the OAuth redirect URI. If unset, it is derived from the
# request host (recommended). Must EXACTLY match an Authorized redirect URI in
# the Google Cloud OAuth client, e.g. https://your-app.vercel.app/api/auth/callback
OAUTH_REDIRECT_URI=

# ---- Weather (Open-Meteo — no API key required) ----
# Default home location for the weather view. Users can override in Settings.
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060
WEATHER_LABEL=Home
WEATHER_TZ=auto
